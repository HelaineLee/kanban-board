# Database
# Used by Prisma and the PostgreSQL adapter.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&sslaccept=accept_invalid_certs&sslmode=disable"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# Optional for production deployments.
# NEXTAUTH_URL="http://localhost:3000"

# Pusher Channels
# Server-side credentials.
PUSHER_APP_ID="replace-with-pusher-app-id"
PUSHER_KEY="replace-with-pusher-key"
PUSHER_SECRET="replace-with-pusher-secret"
PUSHER_CLUSTER="replace-with-pusher-cluster"

# Client-side realtime configuration.
# These should match PUSHER_KEY and PUSHER_CLUSTER above.
NEXT_PUBLIC_PUSHER_KEY="replace-with-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="replace-with-pusher-cluster"
